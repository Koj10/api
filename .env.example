SECRET_KEY=замените_на_случайную_строку_64_символа
DEBUG=False
JWT_ACCESS_EXPIRES_HOURS=24

# Почта: auto | brevo | resend | smtp
# auto — Brevo, если задан BREVO_API_KEY; иначе Resend; иначе SMTP
EMAIL_PROVIDER=brevo

FROM_EMAIL=gamesense.ghost@gmail.com
FROM_NAME=GameSense

# Brevo (рекомендуется, если VPS блокирует SMTP-порты)
# Ключ: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# Resend (альтернатива)
# RESEND_API_KEY=

# SMTP (если порты 465/587 открыты на сервере)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# FROM_EMAIL можно не дублировать, если совпадает с SMTP_USER

SHOP_ID=
CASHBOX_ID=
ALLOWED_API_KEYS=
