# === Обязательно ===
# Секрет Flask/JWT (сгенерируйте: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-generate-a-long-random-string

# === Опционально ===
DEBUG=False
JWT_ACCESS_EXPIRES_HOURS=24
# Ключи для защищённых эндпоинтов (через запятую, без пробелов вокруг запятых)
ALLOWED_API_KEYS=

# Путь к SQLite (по умолчанию: папка api + gamesense.db)
# DB_PATH=

# ЮKassa (личный кабинет → настройки магазина)
SHOP_ID=
CASHBOX_ID=

# SMTP (письма сброса пароля и т.п.)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Если пусто — подставится SMTP_USER
FROM_EMAIL=
